#!/bin/sh

PURPLE='\033[0;35m'
NC='\033[0m'

echo ""
echo "${PURPLE}git checkout master${NC}"
git checkout master

echo ""
echo "${PURPLE}git fetch --all --prune${NC}"
git fetch --all --prune

echo ""
echo "${PURPLE}git pull${NC}"
git pull

echo ""
echo "${PURPLE}git push origin master${NC}"
git push origin master
