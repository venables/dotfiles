[core]
	editor = vim
	excludesfile = ~/.gitignore
	quotepath = false
[user]
	name = Matt Venables
	email = matt@venabl.es
[color]
	ui = true
[alias]
	a = add
	b = branch
	c = commit
	ca = commit --all
	co = checkout
	cob = checkout -b
	d = diff
	fap = fetch --all --prune
	fop = fetch origin --prune
	l = log --graph --decorate --pretty=oneline --abbrev-commit
	la = log --graph --decorate --pretty=oneline --abbrev-commit --all
	ll = !git --no-pager l
	lla = !git --no-pager la
	p = push
	pr = pull-request
	pom = push origin master
	s = status
	su = submodule update --init
	ru = remote update
	ro = rebase origin/master
	r = rebase
[merge]
	conflictstyle = diff3
[credential]
	helper = osxkeychain
