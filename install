#!/usr/bin/env bash

# Install script for Matt's dotfiles.
# This script is safe to be run multiple times

# Get the root directory of this repo
DIR="$( cd "$( dirname "$0" )" && pwd )"

function brew_install_if_missing {
  if brew ls --versions $1 > /dev/null; then
    # The package is installed
    echo "$1 already installed, skipping."
  else
    brew install $1
  fi
}

function gem_install_if_missing {
  if `gem list $1 -i`; then
    echo "gem $1 already installed, skipping."
  else
    gem install $1
  fi
}

echo ""
echo "Installing homebrew ..."
echo ""

if [ -z "$( command -v brew )" ]; then
  /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
fi

echo ""
echo "Installing homebrew packages..."
echo ""

packages=(
  git
  hub
  zsh
  zsh-completions
  ctags
  yarn
  tidy-html5
  postgresql
  redis
  ag
  coreutils
  gpg
  automake
  autoconf
  openssl
  libyaml
  readline
  libxslt
  libtool
  unixodbc
  python3
)
for i in "${packages[@]}"
do
  brew_install_if_missing $i
done

# Install macvim
if brew ls --versions macvim > /dev/null; then
  # The package is installed
  echo "macvim already installed, skipping."
else
  brew install macvim --with-python3
fi

# Install neovim
mkdir -p ~/.config/nvim
if brew ls --versions neovim > /dev/null; then
  echo "neovim already installed, skipping"
else
  brew tap neovim/neovim
  brew install neovim
  pip3 install neovim
fi

echo ""
echo "Installing fonts..."
echo ""
# Install fonts
cp $DIR/resources/fonts/SourceCodePro/*.ttf ~/Library/Fonts

echo ""
echo "Installing iTerm Settings..."
echo ""
# Install iTerm Settings
defaults write com.googlecode.iterm2.plist PrefsCustomFolder -string "~/.dotfiles/resources/iterm"
defaults write com.googlecode.iterm2.plist LoadPrefsFromCustomFolder -bool true

echo ""
echo "Installing dotfiles..."
echo ""
# Symlink all dotfiles to ~/
ln -sf $DIR/agignore ~/.agignore
ln -sf $DIR/gitconfig ~/.gitconfig
ln -sf $DIR/gitignore ~/.gitignore
ln -sf $DIR/hushlogin ~/.hushlogin
ln -sf $DIR/vimrc ~/.config/nvim/init.vim
ln -sf ~/.config/nvim/init.vim ~/.vimrc
ln -sf $DIR/zshrc ~/.zshrc
ln -sf $DIR/ctags ~/.ctags

echo ""
echo "Installing bin..."
echo ""
# Symlink bin files
ln -sf $DIR/bin/db /usr/local/bin/db
ln -sf $DIR/bin/git-cleanup /usr/local/bin/git-cleanup
ln -sf $DIR/bin/git-sync /usr/local/bin/git-sync

echo ""
echo "Installing asdf..."
echo ""
if [ ! -d ~/.asdf ]
then
  git clone https://github.com/asdf-vm/asdf.git ~/.asdf --branch v0.4.0
fi

echo ""
echo "Installing languages..."
echo ""
bash ~/.asdf/plugins/nodejs/bin/import-release-team-keyring
# Erlang
~/.asdf/bin/asdf plugin-add erlang
~/.asdf/bin/asdf install erlang 20.1
~/.asdf/bin/asdf global erlang 20.1

# Elixir
~/.asdf/bin/asdf plugin-add elixir
~/.asdf/bin/asdf install elixir 1.5.2
~/.asdf/bin/asdf install elixir master
~/.asdf/bin/asdf global elixir 1.5.2

# Nodejs
~/.asdf/bin/asdf plugin-add nodejs
~/.asdf/bin/asdf install nodejs 8.9.0
~/.asdf/bin/asdf global nodejs 8.9.0

# Ruby
~/.asdf/bin/asdf plugin-add ruby
~/.asdf/bin/asdf install ruby 2.4.2
~/.asdf/bin/asdf global ruby 2.4.2

gem_install_if_missing bundler
gem_install_if_missing invoker
~/.asdf/bin/asdf reshim ruby

echo ""
echo "Installing vim-plug..."
echo ""
# Install plug-vim
if [ ! -d ~/.local/share/nvim/plugged ]
then
  curl -fLo ~/.local/share/nvim/site/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi

if [ ! -f ~/.vim/autoload/plug.vim ]
then
  curl -fLo ~/.vim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi

echo ""
echo "Installing colors..."
echo ""
# Set up colors
if [ ! -d ~/.config/base16-shell ]
then
  git clone https://github.com/chriskempson/base16-shell.git ~/.config/base16-shell
fi

echo ""
echo "Installing tab completion..."
echo ""
# zsh tab completion
if [ ! -d ~/.zsh/completion ]
then
  mkdir -p ~/.zsh/completion
  curl -L https://raw.githubusercontent.com/docker/compose/$(docker-compose version --short)/contrib/completion/zsh/_docker-compose > ~/.zsh/completion/_docker-compose
fi

echo ""
echo "Setting up /work directory ..."
echo ""

if [ ! -d ~/dev ]
then
  mkdir -p ~/dev
  sudo ln -s ~/dev /work
fi

echo ""
echo "Ensuring zsh is default shell ..."
echo ""

if [ -z "$(grep "$(which zsh)" "/etc/shells")" ]; then
  which zsh | sudo tee -a /etc/shells
  chsh -s $(which zsh)
fi

echo "Done."
