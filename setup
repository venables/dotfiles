#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$HOME/.dotfiles"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

info() { printf '\033[1;34m==>\033[0m %s\n' "$1"; }
ok()   { printf '\033[1;32m  OK\033[0m %s\n' "$1"; }
skip() { printf '\033[1;33m  SKIP\033[0m %s\n' "$1"; }

command_exists() { command -v "$1" &>/dev/null; }

# ---------------------------------------------------------------------------
# Flags
# ---------------------------------------------------------------------------

SETUP_MACOS=false

for arg in "$@"; do
  case "$arg" in
    --macos) SETUP_MACOS=true ;;
    *)
      echo "Usage: ./setup [--macos]"
      echo "  --macos  Apply macOS defaults (key repeat, hot corners, etc.)"
      exit 1
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Homebrew
# ---------------------------------------------------------------------------

info "Homebrew"

if ! command_exists brew; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  ok "installed"
else
  ok "already installed"
fi

eval "$(/opt/homebrew/bin/brew shellenv)"

info "Homebrew packages"
brew bundle --file="$DOTFILES/homebrew/.Brewfile"
ok "bundled"

# ---------------------------------------------------------------------------
# Stow
# ---------------------------------------------------------------------------

info "Stow symlinks"

stow_packages=(
  agents
  formatters
  ghostty
  git
  homebrew
  hushlogin
  mise
  nvim
  ssh
  starship
  tmux
  zed
  zsh
)

for pkg in "${stow_packages[@]}"; do
  if [[ -d "$DOTFILES/$pkg" ]]; then
    stow -d "$DOTFILES" -t "$HOME" "$pkg"
    ok "$pkg"
  else
    skip "$pkg (directory not found)"
  fi
done

# ---------------------------------------------------------------------------
# Compinit fix
# ---------------------------------------------------------------------------

info "Fixing zsh compinit permissions"

insecure_dirs="$(zsh -c 'autoload -Uz compaudit && compaudit' 2>/dev/null || true)"
if [[ -n "$insecure_dirs" ]]; then
  echo "$insecure_dirs" | xargs chmod go-w
  ok "fixed"
else
  ok "none needed"
fi

# ---------------------------------------------------------------------------
# Shell
# ---------------------------------------------------------------------------

info "Default shell"

brew_zsh="$(brew --prefix)/bin/zsh"
if [[ "$SHELL" == "$brew_zsh" ]]; then
  ok "already set to $brew_zsh"
else
  if ! grep -qF "$brew_zsh" /etc/shells; then
    sudo sh -c "echo '$brew_zsh' >> /etc/shells"
  fi
  chsh -s "$brew_zsh"
  ok "changed to $brew_zsh"
fi

# ---------------------------------------------------------------------------
# mise (install runtimes before anything that depends on them)
# ---------------------------------------------------------------------------

info "mise runtimes"

if command_exists mise; then
  mise install --yes
  eval "$(mise activate bash)"
  ok "installed and activated"
else
  skip "mise not found (should have been installed by brew bundle)"
fi

# ---------------------------------------------------------------------------
# CLI tools (installed outside homebrew for auto-update support)
# Re-running the install scripts updates existing installs.
# ---------------------------------------------------------------------------

info "CLI tools"

install_cli() {
  info "  $1"
  curl -fsSL "$2" | bash
  ok "$1"
}

install_cli "opencode" "https://opencode.ai/install"
install_cli "claude"   "https://claude.ai/install.sh"
# install_cli "amp"      "https://amp.dev/install.sh"
# install_cli "droid"    "https://app.factory.ai/cli"
# install_cli "openclaw" "https://openclaw.ai/install.sh"

# ---------------------------------------------------------------------------
# Global npm packages
# ---------------------------------------------------------------------------

info "Global npm packages"

export NPM_CONFIG_PREFIX="$HOME/.npm-global"

npm install -g \
  @mariozechner/pi-coding-agent@latest \
  @openai/codex@latest \
  fixjson \
  openclaw@latest \
  oxfmt \
  oxlint \
  oxlint-tsgolint \
  prettier

ok "installed"

# ---------------------------------------------------------------------------
# GPG
# ---------------------------------------------------------------------------

info "GPG config"

mkdir -p "$HOME/.gnupg"
gpg_conf="$HOME/.gnupg/gpg-agent.conf"
pinentry_line="pinentry-program /opt/homebrew/bin/pinentry-mac"

if [[ -f "$gpg_conf" ]] && grep -qF "$pinentry_line" "$gpg_conf"; then
  ok "already configured"
else
  echo "$pinentry_line" >> "$gpg_conf"
  ok "configured"
fi

# ---------------------------------------------------------------------------
# GitHub CLI extensions
# ---------------------------------------------------------------------------

info "GitHub CLI extensions"

gh_extensions=(
  dlvhdr/gh-dash
  seachicken/gh-poi
  meiji163/gh-notify
)

if command_exists gh; then
  installed_extensions="$(gh ext list 2>/dev/null || true)"
  for ext in "${gh_extensions[@]}"; do
    if echo "$installed_extensions" | grep -qF "$ext"; then
      if gh ext upgrade "$ext" 2>/dev/null; then
        ok "$ext upgraded"
      else
        skip "$ext upgrade failed"
      fi
    else
      gh ext install "$ext"
      ok "$ext installed"
    fi
  done
else
  skip "gh not found"
fi

# ---------------------------------------------------------------------------
# macOS defaults (opt-in via --macos)
# ---------------------------------------------------------------------------

if $SETUP_MACOS; then
  info "macOS defaults"

  # Key repeat
  defaults write -g InitialKeyRepeat -int 12
  defaults write -g KeyRepeat -int 2

  # Disable press and hold
  defaults write -g ApplePressAndHoldEnabled -bool false

  # Finder: folders first
  defaults write com.apple.finder _FXSortFoldersFirst -bool true

  # Hot corners
  defaults write com.apple.dock wvous-tl-corner -int 5
  defaults write com.apple.dock wvous-tr-corner -int 3
  defaults write com.apple.dock wvous-bl-corner -int 2
  defaults write com.apple.dock wvous-br-corner -int 4

  # Lock screen after 5s
  defaults write com.apple.screensaver askForPassword -int 1
  defaults write com.apple.screensaver askForPasswordDelay -int 5

  # Disable auto-corrections
  defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
  defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
  defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
  defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false

  ok "defaults written"

  # Restart affected services
  killall Dock 2>/dev/null || true
  killall Finder 2>/dev/null || true
  killall SystemUIServer 2>/dev/null || true
  ok "services restarted"
fi

# ---------------------------------------------------------------------------

echo ""
info "Setup complete"
